# ============================================================
# APG Flight Agent v2.2 — Cấu hình
# Copy file này thành .env.local rồi chỉnh theo nhu cầu
# ============================================================

# NODE_ENV: development | production
# - development = thử scrape abay.vn, nếu thất bại → dùng mock
# - production  = chỉ scrape abay.vn thực, không dùng mock
NODE_ENV=development

# ABAY_MOCK: true | false (mặc định false)
# - true  = BẮT BUỘC dùng mock data (bất kể NODE_ENV)
# - false = scrape abay.vn thực (khuyến nghị)
ABAY_MOCK=false

# Cache TTL (giây) — mặc định 900 = 15 phút
CACHE_TTL=900

# PORT mặc định 3000
# PORT=3000

# API Key cho n8n (đổi thành key bí mật của bạn)
API_SECRET_KEY=your-secret-key-here
